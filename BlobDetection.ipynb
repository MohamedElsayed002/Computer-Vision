    {
      "cell_type": "code",
      "source": [
        "house = imread('house.JPG')\n",
        "fig , axis = plt.subplots(1,2,figsize=(12,6))\n",
        "axis[0].imshow(house)\n",
        "axis[0].set_title('Original Image')\n",
        "\n",
        "axis[1].imshow(mask,cmap='gray')\n",
        "axis[1].set_title('Binary Mask')"
      ],
