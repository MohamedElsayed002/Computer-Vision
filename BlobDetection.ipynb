    {
      "cell_type": "markdown",
      "source": [
        "# Laplacian of Gaussian (LoG)\n"
      ],
      "metadata": {
        "id": "LreYepIi22-c"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "blobs = blob_log(mask,min_sigma=30)\n",
        "fig,ax = plt.subplots(figsize=(6,6))\n",
        "ax.imshow(house)\n",
        "for blob in blobs:\n",
        "  y,x,area = blob\n",
        "  ax.add_patch(plt.Circle((x,y),area*np.sqrt(2),color='r',fill=False))"
      ],
